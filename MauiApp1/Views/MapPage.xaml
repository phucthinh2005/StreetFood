<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             xmlns:lang="clr-namespace:MauiApp1.Resources.Languages"
             x:Class="MauiApp1.Views.MapPage"
             BackgroundColor="#F2F2F2"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!-- HEADER -->
        <Border Grid.Row="0"
                BackgroundColor="#FF6B35"
                Padding="16">

            <Border.Shadow>
                <Shadow Brush="#33000000"
                        Offset="0,3"
                        Radius="8"/>
            </Border.Shadow>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="40" />
                </Grid.ColumnDefinitions>

                <StackLayout Spacing="2">

                    <Label FontAttributes="Bold"
                           TextColor="White"
                           FontSize="18">

                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="🍜 " />
                                <Span Text="{x:Static lang:AppResources.FoodStreet}" />
                            </FormattedString>
                        </Label.FormattedText>

                    </Label>

                    <Label FontSize="12"
                           TextColor="#FFF0F0">

                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="🎧 " />
                                <Span Text="{x:Static lang:AppResources.AutoGuide}" />
                            </FormattedString>
                        </Label.FormattedText>

                    </Label>

                </StackLayout>

                <!-- Setting Button -->
                <ImageButton Grid.Column="1"
                             Source="setting.png"
                             BackgroundColor="Transparent"
                             HeightRequest="28"
                             WidthRequest="28"
                             Clicked="OnSettingClicked"/>

            </Grid>

        </Border>


        <!-- MAP -->
        <Grid Grid.Row="1">

            <maps:Map
                x:Name="map"
                IsShowingUser="True"/>

            <!-- LIST BUTTON (GÓC TRÁI DƯỚI) -->
            <Border HorizontalOptions="Start"
                    VerticalOptions="End"
                    Margin="16"
                    Padding="12"
                    BackgroundColor="White"
                    StrokeThickness="0">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20"/>
                </Border.StrokeShape>

                <Border.Shadow>
                    <Shadow Brush="#22000000"
                            Offset="0,2"
                            Radius="6"/>
                </Border.Shadow>

                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnListTabTapped"/>
                </Border.GestureRecognizers>

                <Label FontAttributes="Bold">

                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="📋 " />
                            <Span Text="{x:Static lang:AppResources.List}" />
                        </FormattedString>
                    </Label.FormattedText>

                </Label>

            </Border>

        </Grid>

    </Grid>

</ContentPage>