<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Views.MapPage"
             BackgroundColor="#F2F2F2"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*">
        <!-- Header -->
        <Grid Padding="16" Background="#FF6B35" Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
            </Grid.ColumnDefinitions>
            <StackLayout Spacing="2">
                <Label Text="Phố Ẩm Thực" FontAttributes="Bold" TextColor="White" FontSize="18"/>
                <Label Text="Thuyết minh tự động đa ngôn ngữ" FontSize="12" TextColor="#FFF0F0" />
            </StackLayout>
            <ImageButton Grid.Column="1" Source="dotnet_bot.png" BackgroundColor="Transparent" HeightRequest="36" WidthRequest="36"/>
        </Grid>

        <!-- Tabs -->
        <!-- Tabs -->
        <Grid Row="1" BackgroundColor="White">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Tab: Bản đồ -->
            <Border Grid.Column="0"
            BackgroundColor="#FFF7F2"
            Padding="12"
            StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="6"/>
                </Border.StrokeShape>

                <Label Text="Bản đồ"
               HorizontalOptions="Center"
               VerticalOptions="Center"/>
            </Border>

            <!-- Tab: Danh sách -->
            <!-- Tab: Danh sách -->
            <Border Grid.Column="1"
        BackgroundColor="Transparent"
        Padding="12"
        StrokeThickness="0">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="6"/>
                </Border.StrokeShape>

                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnListTabTapped"/>
                </Border.GestureRecognizers>

                <Label Text="Danh sách "
           HorizontalOptions="Center"
           VerticalOptions="Center"/>
            </Border>

        </Grid>

        <!-- Map area (WebView + Leaflet) -->
        <Grid Row="2">
            <WebView x:Name="mapWebView" BackgroundColor="Transparent" />
            <!-- gọi map -->
            <!-- Zoom controls overlay -->
            <StackLayout Orientation="Vertical" VerticalOptions="Start" HorizontalOptions="Start" Margin="8" Spacing="6">
                <Button x:Name="ZoomInButton" Text="+" WidthRequest="40" HeightRequest="40" Clicked="ZoomIn_Clicked" />
                <Button x:Name="ZoomOutButton" Text="-" WidthRequest="40" HeightRequest="40" Clicked="ZoomOut_Clicked" />
            </StackLayout>
        </Grid>
    </Grid>
    
    

</ContentPage>
    
    