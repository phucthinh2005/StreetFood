<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="MauiApp1.Views.MapPage"
             BackgroundColor="#F2F2F2"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Header -->
        <Grid Padding="16" Background="#FF6B35" Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
            </Grid.ColumnDefinitions>

            <StackLayout Spacing="2">
                <Label Text="Phố Ẩm Thực"
                       FontAttributes="Bold"
                       TextColor="White"
                       FontSize="18"/>

                <Label Text="Thuyết minh tự động đa ngôn ngữ"
                       FontSize="12"
                       TextColor="#FFF0F0" />
            </StackLayout>

            <ImageButton Grid.Column="1"
                         Source="dotnet_bot.png"
                         BackgroundColor="Transparent"
                         HeightRequest="36"
                         WidthRequest="36"/>
        </Grid>

        <!-- Tabs -->
        <Grid Row="1" BackgroundColor="White">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BackgroundColor="#FFF7F2"
                    Padding="12"
                    StrokeThickness="0">

                <Label Text="Bản đồ"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>

            <Border Grid.Column="1"
                    Padding="12"
                    StrokeThickness="0">

                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnListTabTapped"/>
                </Border.GestureRecognizers>

                <Label Text="Danh sách"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>

        </Grid>

        <!-- MAP -->
        <maps:Map
    x:Name="map"
    Grid.Row="2"
    IsShowingUser="True"/>

    </Grid>

</ContentPage>