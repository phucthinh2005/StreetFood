<?xml version="1.0" encoding="utf-8" ?>

<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
    xmlns:lang="clr-namespace:MauiApp1.Resources.Languages"
    x:Class="MauiApp1.Views.MapPage"
    BackgroundColor="#F2F2F2"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- HEADER -->
        <Border Grid.Row="0"
                BackgroundColor="#4CAF50"
                Padding="9">

            <Border.Shadow>
                <Shadow Brush="#33000000"
                        Offset="0,3"
                        Radius="8"/>
            </Border.Shadow>

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="15"/>
            </Border.StrokeShape>

            <StackLayout Spacing="2">

                <Label FontAttributes="Bold"
                       TextColor="White"
                       FontSize="20">

                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="   🍜 " />
                            <Span Text="{x:Static lang:AppResources.FoodStreet}" />
                        </FormattedString>
                    </Label.FormattedText>

                </Label>

                <Label FontSize="15"
                       TextColor="#FFF0F0">

                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="     🎧 " />
                            <Span Text="{x:Static lang:AppResources.AutoGuide}" />
                        </FormattedString>
                    </Label.FormattedText>

                </Label>

            </StackLayout>

        </Border>


        <!-- MAP -->
        <maps:Map
            x:Name="map"
            Grid.Row="1"
            IsShowingUser="True"/>


        <!-- FOOTER -->
        <Border Grid.Row="2"
                BackgroundColor="#4CAF50"
                Padding="10"
                Margin="5"
                StrokeThickness="0">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="18"/>
            </Border.StrokeShape>

            <Border.Shadow>
                <Shadow Brush="#33000000"
                        Offset="0,3"
                        Radius="10"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="*,*">

                <!-- LIST -->
                <VerticalStackLayout Grid.Column="0"
                                     Spacing="4"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center">

                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnListTabTapped"/>
                    </VerticalStackLayout.GestureRecognizers>

                    <Image Source="list.png"
                           HeightRequest="25"
                           WidthRequest="25"
                           HorizontalOptions="Center"/>

                    <Label Text="{x:Static lang:AppResources.List}"
                           FontSize="14"
                           TextColor="Black"
                           HorizontalOptions="Center"/>

                </VerticalStackLayout>


                <!-- SETTING -->
                <VerticalStackLayout Grid.Column="1"
                                     Spacing="4"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center">

                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSettingClicked"/>
                    </VerticalStackLayout.GestureRecognizers>

                    <Image Source="setting.png"
                           HeightRequest="25"
                           WidthRequest="25"
                           HorizontalOptions="Center"/>

                    <Label Text="{x:Static lang:AppResources.Settings}"
                           FontSize="14"
                           TextColor="Black"
                           HorizontalOptions="Center"/>

                </VerticalStackLayout>

            </Grid>

        </Border>

    </Grid>

</ContentPage>