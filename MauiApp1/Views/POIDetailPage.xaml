<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:res="clr-namespace:MauiApp1.Resources.Languages"
             x:Class="MauiApp1.Views.POIDetailPage"
             BackgroundColor="#F6F7FB"
             Shell.NavBarIsVisible="False">

    <Grid>

        <!-- CONTENT -->
        <ScrollView>
            <VerticalStackLayout Padding="20"
                                 Spacing="22">

                <!-- TITLE -->
                <Label FontSize="28"
                       FontAttributes="Bold"
                       HorizontalOptions="Center">

                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="🍜 "/>
                            <Span Text="{Binding SelectedPOI.Name}"/>
                        </FormattedString>
                    </Label.FormattedText>

                </Label>

                <Label Text="{x:Static res:AppResources.VietnamFood}"
                       TextColor="Gray"
                       HorizontalOptions="Center"
                       FontSize="13"/>

                <!-- IMAGE -->
                <Border Padding="0">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>

                    <Border.Shadow>
                        <Shadow Brush="#30000000"
                                Offset="0,6"
                                Radius="14"/>
                    </Border.Shadow>

                    <Image Source="{Binding SelectedPOI.ImageUrl}"
                           HeightRequest="230"
                           Aspect="AspectFill"/>
                </Border>


                <!-- INTRO CARD -->
                <Border BackgroundColor="White"
                        Padding="18">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18"/>
                    </Border.StrokeShape>

                    <Border.Shadow>
                        <Shadow Brush="#22000000"
                                Offset="0,3"
                                Radius="10"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="10">

                        <Label FontAttributes="Bold"
                               FontSize="16">

                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="📖 "/>
                                    <Span Text="{x:Static res:AppResources.Introduction}"/>
                                </FormattedString>
                            </Label.FormattedText>

                        </Label>

                        <Label Text="{Binding SelectedPOI.Description}"
                               FontSize="14"
                               LineHeight="1.4"/>

                    </VerticalStackLayout>

                </Border>


                <!-- AUDIO CARD -->
                <Border BackgroundColor="White"
                        Padding="18">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18"/>
                    </Border.StrokeShape>

                    <Border.Shadow>
                        <Shadow Brush="#22000000"
                                Offset="0,3"
                                Radius="10"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="14">

                        <Grid ColumnDefinitions="*,Auto">

                            <VerticalStackLayout Spacing="3">

                                <Label FontAttributes="Bold"
                                       FontSize="16">

                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="🎧 "/>
                                            <Span Text="{x:Static res:AppResources.AutoAudio}"/>
                                        </FormattedString>
                                    </Label.FormattedText>

                                </Label>

                                <Label Text="{x:Static res:AppResources.AudioDescription}"
                                       FontSize="12"
                                       TextColor="Gray"/>

                            </VerticalStackLayout>

                            <Button Grid.Column="1"
                                    Text="{Binding SpeakButtonText}"
                                    Command="{Binding SpeakCommand}"
                                    BackgroundColor="#FF6B35"
                                    TextColor="White"
                                    CornerRadius="22"
                                    HeightRequest="42"
                                    Padding="20,6"/>
                        </Grid>

                        <BoxView HeightRequest="1"
                                 Color="#EEEEEE"/>

                        <Label Text="{Binding SelectedPOI.Detail}"
                               FontSize="14"
                               LineHeight="1.5"/>

                    </VerticalStackLayout>

                </Border>


                <!-- LOCATION -->
                <Border BackgroundColor="#E3F2FD"
                        Padding="16">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="6">

                        <Label FontAttributes="Bold">

                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="📍 "/>
                                    <Span Text="{x:Static res:AppResources.Location}"/>
                                </FormattedString>
                            </Label.FormattedText>

                        </Label>

                        <Label Text="{Binding SelectedPOI.Address}"
                               FontSize="14"/>

                    </VerticalStackLayout>

                </Border>


                <!-- LANGUAGE -->
                <Border BackgroundColor="#F3E5F5"
                        Padding="16">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="6">

                        <Label FontAttributes="Bold">

                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="🌐 "/>
                                    <Span Text="{x:Static res:AppResources.SupportedLanguage}"/>
                                </FormattedString>
                            </Label.FormattedText>

                        </Label>

                        <Label Text="{Binding SelectedPOI.Language}"/>

                    </VerticalStackLayout>

                </Border>

            </VerticalStackLayout>
        </ScrollView>


        <!-- FLOATING CLOSE BUTTON -->
        <Border BackgroundColor="White"
                Padding="10"
                Margin="16"
                WidthRequest="40"
                HeightRequest="40"
                HorizontalOptions="Start"
                VerticalOptions="Start">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20"/>
            </Border.StrokeShape>

            <Border.Shadow>
                <Shadow Brush="#33000000"
                        Offset="0,3"
                        Radius="8"/>
            </Border.Shadow>

            <Label Text="✕"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   FontAttributes="Bold">

                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CloseCommand}"/>
                </Label.GestureRecognizers>

            </Label>

        </Border>

    </Grid>

</ContentPage>