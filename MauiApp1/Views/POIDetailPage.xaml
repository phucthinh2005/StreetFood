<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Views.POIDetailPage"
             BackgroundColor="#F2F2F2"
             Shell.NavBarIsVisible="False">

    <Grid>

        <!-- NỘI DUNG -->
        <ScrollView>
            <VerticalStackLayout Padding="20,10,20,20"
                                 Spacing="20">

                <!-- TÊN -->
                <Label Text="{Binding Name}"
                       FontSize="26"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>

                <Label Text="Món Việt"
                       TextColor="Gray"
                       HorizontalOptions="Center"/>

                <!-- ẢNH -->
                <Border StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18"/>
                    </Border.StrokeShape>

                    <Image Source="{Binding ImageUrl}"
                           HeightRequest="220"
                           Aspect="AspectFill"/>
                </Border>

                <!-- GIỚI THIỆU -->
                <Label Text="Giới thiệu"
                       FontAttributes="Bold"
                       FontSize="16"/>

                <Label Text="{Binding Description}"
                       FontSize="14"
                       LineHeight="1.3"/>

                <!-- THUYẾT MINH -->
                <Border BackgroundColor="White"
                        Padding="16">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18"/>
                    </Border.StrokeShape>

                    <Border.Shadow>
                        <Shadow Brush="#22000000"
                                Offset="0,3"
                                Radius="10"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="12">

                        <Grid ColumnDefinitions="*,Auto">

                            <VerticalStackLayout Spacing="2">
                                <Label Text="🎧 Thuyết minh tự động"
                                       FontAttributes="Bold"
                                       FontSize="16"/>

                                <Label Text="Nghe nội dung giới thiệu bằng âm thanh"
                                       FontSize="12"
                                       TextColor="Gray"/>
                            </VerticalStackLayout>

                            <Button x:Name="SpeakButton"
                                    Grid.Column="1"
                                    Text="▶ Nghe"
                                    BackgroundColor="#FF6B35"
                                    TextColor="White"
                                    CornerRadius="20"
                                    HeightRequest="40"
                                    Padding="18,6"
                                    Clicked="OnSpeakClicked"/>
                        </Grid>

                        <BoxView HeightRequest="1"
                                 Color="#EEEEEE"/>

                        <Label Text="{Binding Detail}"
                               FontSize="14"
                               LineHeight="1.4"/>
                    </VerticalStackLayout>
                </Border>

                <!-- VỊ TRÍ -->
                <Border BackgroundColor="#E3F2FD"
                        Padding="14">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="📍 Vị trí"
                               FontAttributes="Bold"/>

                        <Label Text="{Binding Latitude, StringFormat='Vĩ độ: {0}'}"/>
                        <Label Text="{Binding Longitude, StringFormat='Kinh độ: {0}'}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- NGÔN NGỮ -->
                <Border BackgroundColor="#F3E5F5"
                        Padding="14">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="🌍 Ngôn ngữ hỗ trợ"
                               FontAttributes="Bold"/>

                        <Label Text="{Binding Language}"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- NÚT BACK FLOATING -->
        <Border BackgroundColor="White"
                Padding="8"
                Margin="16"
                HorizontalOptions="Start"
                VerticalOptions="Start"
                StrokeThickness="0">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20"/>
            </Border.StrokeShape>

            <Border.Shadow>
                <Shadow Brush="#33000000"
                        Offset="0,2"
                        Radius="6"/>
            </Border.Shadow>

            <Label Text="✕"
       FontSize="18"
       FontAttributes="Bold">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCloseClicked"/>
                </Label.GestureRecognizers>
            </Label>
        </Border>

    </Grid>
</ContentPage>