<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:res="clr-namespace:MauiApp1.Resources.Languages"
             x:Class="MauiApp1.Views.ListPage"
             Title="{x:Static res:AppResources.ListTitle}"
             BackgroundColor="#F2F2F2">

    <Grid Padding="12"
          RowDefinitions="Auto,*">

        <!-- SEARCH BAR -->
        <Border BackgroundColor="White"
                Padding="10"
                Margin="0,0,0,10"
                StrokeThickness="0">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20"/>
            </Border.StrokeShape>

            <Border.Shadow>
                <Shadow Brush="#22000000"
                        Offset="0,2"
                        Radius="6"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="8">

                <!-- Thanh tìm kiếm -->
                <SearchBar Grid.Column="1"
                           Placeholder="Search..."
                           BackgroundColor="Transparent"
                           TextChanged="SearchBar_TextChanged"
                           CancelButtonColor="Gray"/>

            </Grid>

        </Border>

        <!-- DANH SÁCH -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding POIs}"
                        SelectionMode="None">

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Border StrokeThickness="0"
                            BackgroundColor="White"
                            Margin="0,6"
                            Padding="10">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>

                        <Border.Shadow>
                            <Shadow Brush="#33000000"
                                    Offset="0,2"
                                    Radius="8"/>
                        </Border.Shadow>

                        <Grid ColumnDefinitions="80,*"
                              ColumnSpacing="10">

                            <!-- Image -->
                            <Image Source="{Binding ImageUrl}"
                                   WidthRequest="80"
                                   HeightRequest="80"
                                   Aspect="AspectFill"
                                   Grid.Column="0"/>

                            <!-- Content -->
                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="4">

                                <Grid ColumnDefinitions="*,Auto,Auto"
                                      ColumnSpacing="12">

                                    <Label Text="{Binding Name}"
                                           FontAttributes="Bold"
                                           FontSize="15"
                                           VerticalOptions="Center"
                                           LineBreakMode="TailTruncation"/>

                                    <!-- Detail -->
                                    <VerticalStackLayout Grid.Column="1"
                                                         Spacing="1"
                                                         HorizontalOptions="Center">

                                        <ImageButton Source="eye2.png"
                                                     Clicked="DetailButton_Clicked"
                                                     CommandParameter="{Binding .}"
                                                     HeightRequest="26"
                                                     WidthRequest="26"
                                                     BackgroundColor="Transparent"/>

                                        <Label Text="{x:Static res:AppResources.Detail}"
                                               FontSize="12"
                                               HorizontalOptions="Center"
                                               TextColor="Black"/>

                                    </VerticalStackLayout>

                                    <!-- Map -->
                                    <VerticalStackLayout Grid.Column="2"
                                                         Spacing="1"
                                                         HorizontalOptions="Center">

                                        <ImageButton Source="map.png"
                                                     Clicked="MapButton_Clicked"
                                                     CommandParameter="{Binding .}"
                                                     HeightRequest="26"
                                                     WidthRequest="26"
                                                     BackgroundColor="Transparent"/>

                                        <Label Text="{x:Static res:AppResources.Map}"
                                               FontSize="12"
                                               HorizontalOptions="Center"
                                               TextColor="Black"/>

                                    </VerticalStackLayout>

                                </Grid>

                                <Label Text="{Binding Description}"
                                       FontSize="12"
                                       TextColor="Gray"/>

                                <Label Text="{Binding Content}"
                                       FontSize="12"
                                       LineBreakMode="TailTruncation"/>

                                <VerticalStackLayout Spacing="2">

                                    <Label Text="{Binding StarDisplay}"
                                           FontSize="14"
                                           TextColor="#FFC107"/>

                                    <Label FontSize="11"
                                           TextColor="Gray">

                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding Rating}"/>
                                                <Span Text=" "/>
                                                <Span Text="{x:Static res:AppResources.Rating}"/>
                                            </FormattedString>
                                        </Label.FormattedText>

                                    </Label>

                                </VerticalStackLayout>

                            </VerticalStackLayout>

                        </Grid>

                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>

</ContentPage>