<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Views.SettingsPage"
             Title="Cài đặt">

	<ScrollView>
		<VerticalStackLayout Padding="20" Spacing="20">

			<!-- Theo dõi vị trí -->
			<Label Text="Theo dõi vị trí"
                   FontAttributes="Bold"
                   FontSize="18"/>

			<Grid ColumnDefinitions="*,Auto">
				<VerticalStackLayout>
					<Label Text="Theo dõi GPS"/>
					<Label Text="Bật để theo dõi vị trí liên tục"
                           FontSize="12"
                           TextColor="Gray"/>
				</VerticalStackLayout>
				<Switch x:Name="gpsSwitch"
                        Grid.Column="1"/>
			</Grid>

			<Grid ColumnDefinitions="*,Auto">
				<VerticalStackLayout>
					<Label Text="Theo dõi nền"/>
					<Label Text="Tiếp tục theo dõi khi ứng dụng ở nền"
                           FontSize="12"
                           TextColor="Gray"/>
				</VerticalStackLayout>
				<Switch x:Name="backgroundSwitch"
                        Grid.Column="1"/>
			</Grid>

			<!-- Âm thanh -->
			<Label Text="Âm thanh"
                   FontAttributes="Bold"
                   FontSize="18"/>

			<Grid ColumnDefinitions="*,Auto">
				<VerticalStackLayout>
					<Label Text="Tự động phát"/>
					<Label Text="Tự động phát thuyết minh khi vào vùng"
                           FontSize="12"
                           TextColor="Gray"/>
				</VerticalStackLayout>
				<Switch x:Name="autoPlaySwitch"
                        Grid.Column="1"/>
			</Grid>

			<Label x:Name="volumeLabel"
                   Text="Âm lượng: 80%"/>

			<Slider x:Name="volumeSlider"
                    Minimum="0"
                    Maximum="100"
                    Value="80"
                    ValueChanged="VolumeChanged"/>

			<Label x:Name="speedLabel"
                   Text="Tốc độ giọng nói: 1.0x"/>

			<Slider x:Name="speedSlider"
                    Minimum="0.5"
                    Maximum="2"
                    Value="1"
                    ValueChanged="SpeedChanged"/>

			<!-- Ngôn ngữ -->
			<Label Text="Ngôn ngữ"
                   FontAttributes="Bold"
                   FontSize="18"/>

			<Label Text="Ngôn ngữ mặc định"/>

			<Picker x:Name="languagePicker">
				<Picker.Items>
					<x:String>English</x:String>
					<x:String>Tiếng Việt</x:String>
					<x:String>日本語</x:String>
				</Picker.Items>
			</Picker>

			<!-- Geofence -->
			<Label Text="Geofence"
                   FontAttributes="Bold"
                   FontSize="18"/>

			<Label x:Name="radiusLabel"
                   Text="Bán kính thông báo mặc định: 50m"/>

			<Slider x:Name="radiusSlider"
                    Minimum="10"
                    Maximum="200"
                    Value="50"
                    ValueChanged="RadiusChanged"/>

			<Label Text="Khoảng cách mặc định để kích hoạt thuyết minh"
                   FontSize="12"
                   TextColor="Gray"/>

			<!-- Quản lý dữ liệu -->
			<Label Text="Quản lý dữ liệu"
                   FontAttributes="Bold"
                   FontSize="18"/>

			<Button Text="⬇ Xuất dữ liệu"
                    BackgroundColor="#eeeeee"
                    TextColor="Black"/>

			<Button Text="⬆ Nhập dữ liệu"
                    BackgroundColor="#eeeeee"
                    TextColor="Black"/>

			<Button Text="🗑 Xóa tất cả dữ liệu"
                    BackgroundColor="Red"
                    TextColor="White"/>

			<Button Text="⟳ Reset về mặc định"
                    BackgroundColor="White"
                    TextColor="Blue"
                    BorderColor="Blue"
                    BorderWidth="1"/>

		</VerticalStackLayout>
	</ScrollView>

</ContentPage>