<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:res="clr-namespace:MauiApp1.Resources.Languages"
             x:Class="MauiApp1.Views.SettingsPage"
             Title="{x:Static res:AppResources.Settings}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <!-- Volume -->
            <Label x:Name="volumeLabel">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="{x:Static res:AppResources.Volume}" />
                        <Span Text=": " />
                        <Span Text="80%" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>

            <Slider x:Name="volumeSlider"
                    Minimum="0"
                    Maximum="100"
                    Value="80"
                    ValueChanged="VolumeChanged"/>

            <!-- Speech Speed -->
            <Label x:Name="speedLabel">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="{x:Static res:AppResources.SpeechSpeed}" />
                        <Span Text=": " />
                        <Span Text="1.0x" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>

            <Slider x:Name="speedSlider"
                    Minimum="0.5"
                    Maximum="2"
                    Value="1"
                    ValueChanged="SpeedChanged"/>

            <!-- Language -->
            <Label Text="{x:Static res:AppResources.Language}"
                   FontAttributes="Bold"
                   FontSize="18"/>

            <Border BackgroundColor="#F5F5F5"
                    StrokeShape="RoundRectangle 12"
                    Padding="15">

                <Grid ColumnDefinitions="Auto,*,Auto">

                    <Label Text="🌐"
                           FontSize="20"
                           VerticalOptions="Center"/>

                    <VerticalStackLayout Grid.Column="1"
                                         Margin="10,0">
                        <Label Text="{x:Static res:AppResources.Language}"/>
                        <Label x:Name="languageLabel"
                               FontSize="12"
                               TextColor="Gray"/>
                    </VerticalStackLayout>

                    <Label Text=">"
                           Grid.Column="2"
                           VerticalOptions="Center"
                           TextColor="Gray"/>

                </Grid>

                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="ChooseLanguage"/>
                </Border.GestureRecognizers>

            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>