<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:res="clr-namespace:MauiApp1.Resources.Languages"
             x:Class="MauiApp1.Views.SettingsPage"
             Title="{x:Static res:AppResources.Settings}">

    <ScrollView>

        <VerticalStackLayout Padding="25" Spacing="30">

            <!-- Volume Card -->
            <Border BackgroundColor="White"
                    StrokeShape="RoundRectangle 20"
                    Padding="20"
                    Shadow="0,4,10,#33000000">

                <VerticalStackLayout Spacing="10">

                    <Label x:Name="volumeLabel"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#333"/>

                    <Slider x:Name="volumeSlider"
                            Minimum="0"
                            Maximum="100"
                            Value="80"
                            ValueChanged="VolumeChanged"/>

                </VerticalStackLayout>

            </Border>


            <!-- Speech Speed Card -->
            <Border BackgroundColor="White"
                    StrokeShape="RoundRectangle 20"
                    Padding="20"
                    Shadow="0,4,10,#33000000">

                <VerticalStackLayout Spacing="10">

                    <Label x:Name="speedLabel"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#333"/>

                    <Slider x:Name="speedSlider"
                            Minimum="0.5"
                            Maximum="2"
                            Value="1"
                            ValueChanged="SpeedChanged"/>

                </VerticalStackLayout>

            </Border>


            <!-- Language -->
            <Label Text="{x:Static res:AppResources.Language}"
                   FontAttributes="Bold"
                   FontSize="18"
                   TextColor="#333"/>

            <Border BackgroundColor="White"
                    StrokeShape="RoundRectangle 20"
                    Padding="18"
                    Shadow="0,4,10,#33000000">

                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="15">

                    <Label Text="🌐"
                           FontSize="22"
                           VerticalOptions="Center"/>

                    <VerticalStackLayout Grid.Column="1">

                        <Label Text="{x:Static res:AppResources.Language}"
                               FontAttributes="Bold"/>

                        <Label x:Name="languageLabel"
                               FontSize="12"
                               TextColor="Gray"/>

                    </VerticalStackLayout>

                    <Label Text="›"
                           Grid.Column="2"
                           FontSize="20"
                           VerticalOptions="Center"
                           TextColor="Gray"/>

                </Grid>

                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="ChooseLanguage"/>
                </Border.GestureRecognizers>

            </Border>


            <!-- Reset -->
            <Border BackgroundColor="#F9FAFF"
        Stroke="#2F80ED"
        StrokeThickness="1.5"
        StrokeShape="RoundRectangle 20"
        Padding="18">

                <Grid ColumnDefinitions="40,*"
          ColumnSpacing="10"
          VerticalOptions="Center">

                    <Label Text="🔄"
               FontSize="22"
               VerticalOptions="Center"
               HorizontalOptions="Center"/>

                    <Label Grid.Column="1"
               Text="{x:Static res:AppResources.ResetDefault}"
               VerticalOptions="Center"
               TextColor="#2F80ED"
               FontAttributes="Bold"
               FontSize="16"
               LineBreakMode="WordWrap"/>

                </Grid>

                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="ResetSettings"/>
                </Border.GestureRecognizers>

            </Border>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>