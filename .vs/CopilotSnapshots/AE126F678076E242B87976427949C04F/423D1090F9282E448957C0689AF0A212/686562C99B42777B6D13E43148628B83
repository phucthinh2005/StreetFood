<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp1.Views.MapPage"
             

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Tabs (centered) -->
        <Grid Row="0" BackgroundColor="White" Padding="12">
            <StackLayout Orientation="Vertical" HorizontalOptions="Center" Spacing="6">
                <StackLayout Orientation="Horizontal" Spacing="24" HorizontalOptions="Center">
                    <Frame HasShadow="False" Padding="12" BackgroundColor="#FFF7F2" CornerRadius="8" WidthRequest="140" HorizontalOptions="Center">
                        <Label Text="Bản đồ" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Frame>
                    <Frame HasShadow="False" Padding="12" BackgroundColor="Transparent" CornerRadius="8" WidthRequest="140" HorizontalOptions="Center">
                        <Label Text="Danh sách (4)" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Frame>
                </StackLayout>
                <Label Text="Chưa có vị trí" HorizontalOptions="Center" Opacity="0.7" />
            </StackLayout>
        </Grid>

        <!-- Map area (WebView + Leaflet) -->
        <Grid Row="2">
            <WebView x:Name="mapWebView" BackgroundColor="Transparent" />

            <!-- Zoom controls overlay -->
            <StackLayout Orientation="Vertical" VerticalOptions="Start" HorizontalOptions="Start" Margin="8" Spacing="6">
                <Button x:Name="ZoomInButton" Text="+" WidthRequest="40" HeightRequest="40" Clicked="ZoomIn_Clicked" />
                <Button x:Name="ZoomOutButton" Text="-" WidthRequest="40" HeightRequest="40" Clicked="ZoomOut_Clicked" />
            </StackLayout>
        </Grid>
    </Grid>

</ContentPage>
